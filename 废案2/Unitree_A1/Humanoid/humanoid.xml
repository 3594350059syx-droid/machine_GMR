<mujoco model="simple_humanoid">
    <compiler angle="degree" coordinate="local"/>
    <option timestep="0.01" gravity="0 0 -9.81" integrator="Euler"/>

    <worldbody>
        <!-- 地面 -->
        <geom name="floor" type="plane" size="5 5 0.1" rgba="0.8 0.9 0.8 1"/>

        <!-- 躯干 -->
        <body name="torso" pos="0 0 1">
            <joint name="torso_fixed" type="free"/>
            <geom name="torso_geom" type="capsule" fromto="0 0 0 0 0 0.5" size="0.1" rgba="0.8 0 0 1"/>

            <!-- 头 -->
            <body name="head" pos="0 0 0.5">
                <joint name="neck" type="hinge" axis="0 1 0" range="-45 45"/>
                <geom name="head_geom" type="sphere" size="0.1" rgba="1 0.8 0 1"/>
            </body>

            <!-- 左臂 -->
            <body name="left_arm" pos="0 0.2 0.4">
                <joint name="left_shoulder" type="hinge" axis="1 0 0" range="-90 90"/>
                <geom name="upper_arm_left" type="capsule" fromto="0 0 0 0 0 -0.25" size="0.05"/>
                <body name="left_forearm" pos="0 0 -0.25">
                    <joint name="left_elbow" type="hinge" axis="1 0 0" range="0 150"/>
                    <geom name="forearm_left" type="capsule" fromto="0 0 0 0 0 -0.25" size="0.04"/>
                </body>
            </body>

            <!-- 右臂 -->
            <body name="right_arm" pos="0 -0.2 0.4">
                <joint name="right_shoulder" type="hinge" axis="1 0 0" range="-90 90"/>
                <geom name="upper_arm_right" type="capsule" fromto="0 0 0 0 0 -0.25" size="0.05"/>
                <body name="right_forearm" pos="0 0 -0.25">
                    <joint name="right_elbow" type="hinge" axis="1 0 0" range="0 150"/>
                    <geom name="forearm_right" type="capsule" fromto="0 0 0 0 0 -0.25" size="0.04"/>
                </body>
            </body>

            <!-- 左腿 -->
            <body name="left_leg" pos="0 0.1 0">
                <joint name="left_hip" type="hinge" axis="1 0 0" range="-60 60"/>
                <geom name="thigh_left" type="capsule" fromto="0 0 0 0 0 -0.4" size="0.06"/>
                <body name="left_shin" pos="0 0 -0.4">
                    <joint name="left_knee" type="hinge" axis="1 0 0" range="0 150"/>
                    <geom name="shin_left" type="capsule" fromto="0 0 0 0 0 -0.4" size="0.05"/>
                </body>
            </body>

            <!-- 右腿 -->
            <body name="right_leg" pos="0 -0.1 0">
                <joint name="right_hip" type="hinge" axis="1 0 0" range="-60 60"/>
                <geom name="thigh_right" type="capsule" fromto="0 0 0 0 0 -0.4" size="0.06"/>
                <body name="right_shin" pos="0 0 -0.4">
                    <joint name="right_knee" type="hinge" axis="1 0 0" range="0 150"/>
                    <geom name="shin_right" type="capsule" fromto="0 0 0 0 0 -0.4" size="0.05"/>
                </body>
            </body>

        </body>
    </worldbody>

<actuator>
    <position name="left_shoulder" joint="left_shoulder" kp="100"/>
    <position name="left_elbow" joint="left_elbow" kp="100"/>
    <position name="right_shoulder" joint="right_shoulder" kp="100"/>
    <position name="right_elbow" joint="right_elbow" kp="100"/>
    <position name="left_hip" joint="left_hip" kp="200"/>
    <position name="left_knee" joint="left_knee" kp="200"/>
    <position name="right_hip" joint="right_hip" kp="200"/>
    <position name="right_knee" joint="right_knee" kp="200"/>
    <position name="neck" joint="neck" kp="50"/>
</actuator>
</mujoco>